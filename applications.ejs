<!DOCTYPE html>
<html lang="en">
<%- include('../includes/head') %>
<body>
<% locals.activePage = 'applications'; %>
<%- include('../includes/sidebar') %>
<%- include('../includes/header') %>

<style>
  .main-content { margin-left: var(--sidebar-w); padding-top: var(--topbar-h); min-height: 100vh; }
  .page-inner { padding: 28px; display: flex; flex-direction: column; gap: 20px; }
  .page-header h1 { font-size: 22px; font-weight: 700; }
  .page-header p { color: var(--text-muted); font-size: 13px; margin-top: 4px; }

  .alert { padding: 12px 16px; border-radius: 8px; font-size: 14px; font-weight: 500; margin-bottom: 4px; }
  .alert-success { background: rgba(59,165,93,0.15); border: 1px solid rgba(59,165,93,0.3); color: var(--success); }
  .alert-error   { background: rgba(237,66,69,0.12); border: 1px solid rgba(237,66,69,0.25); color: var(--danger); }

  .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 22px 24px; }
  .card-title { font-size: 14px; font-weight: 700; color: var(--text-primary); margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
  .card-title i { color: var(--accent); }

  /* Filters */
  .filter-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
  .filter-btn {
    padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600;
    cursor: pointer; border: 1px solid var(--border); background: var(--bg-tertiary);
    color: var(--text-secondary); transition: all .2s; text-decoration: none;
  }
  .filter-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
  .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  .search-box {
    flex: 1; min-width: 180px; padding: 7px 12px;
    background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text-primary); font-size: 13px;
  }
  .search-box:focus { outline: none; border-color: var(--accent); }

  /* Stats row */
  .stats-row { display: flex; gap: 14px; flex-wrap: wrap; }
  .stat-card {
    flex: 1; min-width: 120px; background: var(--bg-tertiary);
    border: 1px solid var(--border); border-radius: 10px;
    padding: 14px 18px; text-align: center;
  }
  .stat-card .stat-num { font-size: 24px; font-weight: 800; }
  .stat-card .stat-label { font-size: 11px; color: var(--text-muted); margin-top: 2px; text-transform: uppercase; letter-spacing: .5px; }
  .stat-pending .stat-num { color: #ffb400; }
  .stat-accepted .stat-num { color: var(--success); }
  .stat-denied .stat-num { color: var(--danger); }
  .stat-total .stat-num { color: var(--accent); }

  /* Empty state */
  .empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
  .empty-state i { font-size: 48px; margin-bottom: 16px; opacity: .4; }
  .empty-state p { font-size: 14px; }

  /* Application cards */
  .app-list { display: flex; flex-direction: column; gap: 14px; }
  .app-card {
    background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 10px; overflow: hidden;
    transition: border-color .2s;
  }
  .app-card:hover { border-color: var(--accent); }
  .app-card.status-accepted { border-left: 3px solid var(--success); }
  .app-card.status-denied   { border-left: 3px solid var(--danger); }
  .app-card.status-pending  { border-left: 3px solid #ffb400; }

  .app-card-header {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 18px; cursor: pointer;
    justify-content: space-between;
  }
  .app-meta { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; }
  .app-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--bg-secondary); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; font-weight: 700; color: var(--accent);
    overflow: hidden;
  }
  .app-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .app-info { min-width: 0; }
  .app-name { font-size: 14px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .app-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

  .app-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .badge {
    padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .5px;
  }
  .badge-pending  { background: rgba(255,180,0,0.15);  color: #ffb400;        border: 1px solid rgba(255,180,0,0.3); }
  .badge-accepted { background: rgba(59,165,93,0.15);  color: var(--success); border: 1px solid rgba(59,165,93,0.3); }
  .badge-denied   { background: rgba(237,66,69,0.12);  color: var(--danger);  border: 1px solid rgba(237,66,69,0.25); }

  .chevron { font-size: 12px; color: var(--text-muted); transition: transform .2s; }
  .app-card.open .chevron { transform: rotate(180deg); }

  /* Expanded body */
  .app-card-body { display: none; padding: 0 18px 16px; border-top: 1px solid var(--border); }
  .app-card.open .app-card-body { display: block; }

  .answers-grid { display: flex; flex-direction: column; gap: 10px; margin-top: 14px; }
  .answer-item {}
  .answer-q { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 3px; }
  .answer-a {
    font-size: 13px; color: var(--text-primary);
    background: var(--bg-secondary); border-radius: 6px;
    padding: 8px 12px; white-space: pre-wrap; word-break: break-word;
  }

  /* Action buttons */
  .action-row { display: flex; gap: 10px; margin-top: 14px; }
  .btn {
    padding: 8px 20px; border-radius: 8px; font-size: 13px; font-weight: 700;
    cursor: pointer; border: none; transition: opacity .2s; text-decoration: none;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .btn:hover { opacity: .85; }
  .btn-accept { background: var(--success); color: #fff; }
  .btn-deny   { background: var(--danger);  color: #fff; }
  .btn-disabled { background: var(--bg-secondary); color: var(--text-muted); cursor: not-allowed; border: 1px solid var(--border); }
  .btn-disabled:hover { opacity: 1; }

  .reviewed-info { font-size: 12px; color: var(--text-muted); margin-top: 10px; }
</style>

<div class="main-content">
  <div class="page-inner">

    <div class="page-header">
      <h1><i class="fa fa-file-alt" style="color:var(--accent);margin-right:8px"></i>Apply Logs</h1>
      <p>View and review all staff applications submitted in this server.</p>
    </div>

    <%
      const totalApps    = applications.length;
      const pendingApps  = applications.filter(a => a.status === 'pending').length;
      const acceptedApps = applications.filter(a => a.status === 'accepted').length;
      const deniedApps   = applications.filter(a => a.status === 'denied').length;
    %>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card stat-total">
        <div class="stat-num"><%= totalApps %></div>
        <div class="stat-label">Total</div>
      </div>
      <div class="stat-card stat-pending">
        <div class="stat-num"><%= pendingApps %></div>
        <div class="stat-label">Pending</div>
      </div>
      <div class="stat-card stat-accepted">
        <div class="stat-num"><%= acceptedApps %></div>
        <div class="stat-label">Accepted</div>
      </div>
      <div class="stat-card stat-denied">
        <div class="stat-num"><%= deniedApps %></div>
        <div class="stat-label">Denied</div>
      </div>
    </div>

    <!-- Applications list -->
    <div class="card">
      <div class="card-title"><i class="fa fa-list"></i> All Applications</div>

      <!-- Filter + Search -->
      <div class="filter-row" style="margin-bottom:16px;">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="pending">Pending</button>
        <button class="filter-btn" data-filter="accepted">Accepted</button>
        <button class="filter-btn" data-filter="denied">Denied</button>
        <input class="search-box" id="app-search" placeholder="Search by username or application name…" />
      </div>

      <% if (applications.length === 0) { %>
        <div class="empty-state">
          <i class="fa fa-inbox"></i>
          <p>No applications submitted yet.<br>Applications will appear here once users run <code>/apply</code> or <code>e!apply</code>.</p>
        </div>
      <% } else { %>
        <div class="app-list" id="app-list">
          <% applications.forEach(function(app) { %>
            <%
              const statusClass = app.status === 'accepted' ? 'status-accepted'
                                : app.status === 'denied'   ? 'status-denied'
                                : 'status-pending';
              const badgeClass  = app.status === 'accepted' ? 'badge-accepted'
                                : app.status === 'denied'   ? 'badge-denied'
                                : 'badge-pending';
              const initials = (app.user_tag || app.user_id).charAt(0).toUpperCase();
              const answersObj = app.answers || {};
              const answerEntries = Object.entries(answersObj);
              const dateStr = new Date(app.submitted_at + ' UTC').toLocaleString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
              });
            %>
            <div class="app-card <%= statusClass %>"
                 data-status="<%= app.status %>"
                 data-search="<%= (app.user_tag + ' ' + app.application_name).toLowerCase() %>">
              <div class="app-card-header" onclick="toggleCard(this)">
                <div class="app-meta">
                  <div class="app-avatar"><%= initials %></div>
                  <div class="app-info">
                    <div class="app-name"><%= app.user_tag || app.user_id %></div>
                    <div class="app-sub"><%= app.application_name %> &middot; <%= dateStr %></div>
                  </div>
                </div>
                <div class="app-right">
                  <span class="badge <%= badgeClass %>"><%= app.status %></span>
                  <i class="fa fa-chevron-down chevron"></i>
                </div>
              </div>

              <div class="app-card-body">
                <div class="answers-grid">
                  <% if (answerEntries.length === 0) { %>
                    <div style="color:var(--text-muted);font-size:13px;">No answers recorded.</div>
                  <% } else { %>
                    <% answerEntries.forEach(function([q, a]) { %>
                      <div class="answer-item">
                        <div class="answer-q"><%= q %></div>
                        <div class="answer-a"><%= a || 'No answer' %></div>
                      </div>
                    <% }); %>
                  <% } %>
                </div>

                <div class="action-row">
                  <% if (app.status === 'pending') { %>
                    <form method="POST" action="/manage/<%= guild.id %>/applications/<%= app.id %>/action" style="display:contents;">
                      <input type="hidden" name="action" value="accepted">
                      <button type="submit" class="btn btn-accept">
                        <i class="fa fa-check"></i> Accept
                      </button>
                    </form>
                    <form method="POST" action="/manage/<%= guild.id %>/applications/<%= app.id %>/action" style="display:contents;">
                      <input type="hidden" name="action" value="denied">
                      <button type="submit" class="btn btn-deny">
                        <i class="fa fa-times"></i> Deny
                      </button>
                    </form>
                  <% } else { %>
                    <span class="btn btn-disabled">
                      <i class="fa fa-lock"></i> Already <%= app.status %>
                    </span>
                  <% } %>
                </div>

                <% if (app.reviewed_by) { %>
                  <div class="reviewed-info">
                    Reviewed by <strong><%= app.reviewed_by %></strong>
                    <% if (app.reviewed_at) { %>
                      &mdash; <%= new Date(app.reviewed_at + ' UTC').toLocaleString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                    <% } %>
                  </div>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
        <div id="no-results" style="display:none;" class="empty-state">
          <i class="fa fa-search"></i>
          <p>No applications match your search.</p>
        </div>
      <% } %>
    </div>

  </div>
</div>

<script>
  function toggleCard(header) {
    const card = header.closest('.app-card');
    card.classList.toggle('open');
  }

  const filterBtns = document.querySelectorAll('.filter-btn');
  const searchBox  = document.getElementById('app-search');
  let activeFilter = 'all';

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  if (searchBox) {
    searchBox.addEventListener('input', applyFilters);
  }

  function applyFilters() {
    const q = searchBox ? searchBox.value.toLowerCase() : '';
    const cards = document.querySelectorAll('.app-card');
    let visible = 0;
    cards.forEach(card => {
      const matchFilter = activeFilter === 'all' || card.dataset.status === activeFilter;
      const matchSearch = !q || card.dataset.search.includes(q);
      const show = matchFilter && matchSearch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const noResults = document.getElementById('no-results');
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
  }
</script>

<%- include('../includes/footer') %>
</body>
</html>
