<!DOCTYPE html>
<html lang="en">
<%- include('../includes/head') %>
<body>
<% locals.activePage = 'discohook'; %>
<%- include('../includes/sidebar') %>
<%- include('../includes/header') %>

<style>
  .main-content { margin-left: var(--sidebar-w); padding-top: var(--topbar-h); min-height: 100vh; }
  .page-inner { padding: 28px; display: flex; flex-direction: column; gap: 20px; }
  .page-header h1 { font-size: 22px; font-weight: 700; }
  .page-header p { color: var(--text-muted); font-size: 13px; margin-top: 4px; }

  /* Alert */
  .alert { padding: 12px 16px; border-radius: 8px; font-size: 14px; font-weight: 500; margin-bottom: 4px; }
  .alert-success { background: rgba(59,165,93,0.15); border: 1px solid rgba(59,165,93,0.3); color: var(--success); }
  .alert-error   { background: rgba(237,66,69,0.12); border: 1px solid rgba(237,66,69,0.25); color: var(--danger); }

  /* Main layout */
  .dh-layout { display: grid; grid-template-columns: 1fr 400px; gap: 20px; align-items: start; }
  @media(max-width:900px){ .dh-layout { grid-template-columns: 1fr; } }

  /* Card */
  .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 22px 24px; }
  .card-title { font-size: 14px; font-weight: 700; color: var(--text-primary); margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
  .card-title i { color: var(--accent); }

  /* Tabs */
  .tab-row { display: flex; gap: 6px; margin-bottom: 20px; }
  .tab-btn {
    padding: 7px 18px; border-radius: 20px; font-size: 13px; font-weight: 600;
    cursor: pointer; border: 1px solid var(--border); background: var(--bg-tertiary);
    color: var(--text-secondary); transition: all .2s;
  }
  .tab-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  /* Form */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
  .form-group label { font-size: 12px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .5px; }
  .form-group input, .form-group select, .form-group textarea {
    background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 8px; padding: 9px 12px; color: var(--text-primary);
    font-size: 14px; font-family: inherit; transition: border-color .2s; width: 100%;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--accent); }
  .form-group textarea { resize: vertical; min-height: 90px; }
  .form-group select option { background: var(--bg-secondary); }

  /* Color row */
  .color-row { display: flex; align-items: center; gap: 10px; }
  .color-row input[type=color] { width: 44px; height: 38px; border-radius: 8px; padding: 3px; cursor: pointer; border: 1px solid var(--border); background: var(--bg-tertiary); flex-shrink: 0; }
  .color-row input[type=text] { flex: 1; }

  /* Divider */
  .divider { height: 1px; background: var(--border); margin: 6px 0 16px; }

  /* Send button */
  .btn-send {
    width: 100%; padding: 12px; border-radius: 10px; font-size: 15px; font-weight: 700;
    background: var(--accent); color: #fff; border: none; cursor: pointer; transition: opacity .2s;
    display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 4px;
  }
  .btn-send:hover { opacity: .85; }

  /* ── Preview ── */
  .preview-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 10px; }
  .webhook-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .webhook-avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; background: var(--accent); display: flex; align-items: center; justify-content: center; font-weight: 700; color: #fff; font-size: 15px; flex-shrink: 0; }
  .webhook-name { font-size: 14px; font-weight: 700; }
  .bot-tag { font-size: 10px; background: var(--accent); color: #fff; padding: 1px 5px; border-radius: 4px; margin-left: 5px; font-weight: 600; vertical-align: middle; }

  .embed-preview {
    border-left: 4px solid #F5A623;
    background: rgba(255,255,255,0.04);
    border-radius: 0 6px 6px 0;
    padding: 12px 14px;
    margin-top: 4px;
  }
  .ep-author { font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px; }
  .ep-title { font-size: 16px; font-weight: 700; color: #00b0f4; margin-bottom: 6px; word-break: break-word; }
  .ep-title a:hover { text-decoration: underline; }
  .ep-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.6; white-space: pre-wrap; word-break: break-word; margin-bottom: 8px; }
  .ep-image { width: 100%; border-radius: 6px; margin-top: 8px; max-height: 200px; object-fit: cover; }
  .ep-thumb { float: right; margin-left: 12px; width: 72px; height: 72px; border-radius: 6px; object-fit: cover; }
  .ep-footer { font-size: 11px; color: var(--text-muted); margin-top: 10px; clear: both; }
  .ep-empty { color: var(--text-muted); font-size: 13px; text-align: center; padding: 20px 0; }

  .raw-preview {
    background: rgba(255,255,255,0.04); border-radius: 8px;
    padding: 12px 14px; font-size: 14px; color: var(--text-primary);
    white-space: pre-wrap; word-break: break-word; min-height: 60px;
  }
</style>

<div class="main-content">
  <div class="page-inner">
    <div class="page-header">
      <h1><i class="fa fa-paper-plane" style="color:var(--accent);margin-right:8px"></i>Discohook</h1>
      <p>Build and send custom embed or raw messages to any channel via webhook</p>
    </div>

    <% if (locals.result) { %>
      <div class="alert <%= result.success ? 'alert-success' : 'alert-error' %>"><%= result.message %></div>
    <% } %>

    <form method="POST" action="/manage/<%= guild.id %>/discohook" id="dhForm">
      <input type="hidden" name="mode" id="modeInput" value="<%= locals.formData?.mode || 'embed' %>">

      <div class="dh-layout">
        <!-- ── LEFT: Builder ── -->
        <div style="display:flex;flex-direction:column;gap:16px;">

          <!-- Channel + Webhook Identity -->
          <div class="card">
            <div class="card-title"><i class="fa fa-satellite-dish"></i> Destination & Identity</div>
            <div class="form-row">
              <div class="form-group">
                <label>Channel</label>
                <select name="channelId" id="channelId" required>
                  <option value="">— select a channel —</option>
                  <% textChannels.forEach(ch => { %>
                    <option value="<%= ch.id %>" <%= (locals.formData?.channelId === ch.id) ? 'selected' : '' %>>#<%= ch.name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="form-group">
                <label>Webhook Name</label>
                <input type="text" name="webhookName" id="webhookName" placeholder="<%= bot.user.username %>" value="<%= locals.formData?.webhookName || '' %>" oninput="updatePreview()">
              </div>
            </div>
            <div class="form-group">
              <label>Webhook Avatar URL <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
              <input type="url" name="webhookAvatar" id="webhookAvatar" placeholder="https://i.imgur.com/..." value="<%= locals.formData?.webhookAvatar || '' %>" oninput="updatePreview()">
            </div>
          </div>

          <!-- Mode tabs + Content -->
          <div class="card">
            <div class="card-title"><i class="fa fa-edit"></i> Message Content</div>

            <div class="tab-row">
              <div class="tab-btn <%= (!locals.formData || locals.formData.mode !== 'raw') ? 'active' : '' %>" onclick="setMode('embed', this)">
                <i class="fa fa-layer-group"></i> Embed
              </div>
              <div class="tab-btn <%= (locals.formData?.mode === 'raw') ? 'active' : '' %>" onclick="setMode('raw', this)">
                <i class="fa fa-align-left"></i> Raw Message
              </div>
            </div>

            <!-- Embed fields -->
            <div id="embedFields" style="display:<%= (locals.formData?.mode === 'raw') ? 'none' : 'block' %>">
              <div class="form-group">
                <label>Author</label>
                <input type="text" name="embedAuthor" id="embedAuthor" placeholder="Author name..." value="<%= locals.formData?.embedAuthor || '' %>" oninput="updatePreview()">
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Title</label>
                  <input type="text" name="embedTitle" id="embedTitle" placeholder="Embed title..." value="<%= locals.formData?.embedTitle || '' %>" oninput="updatePreview()">
                </div>
                <div class="form-group">
                  <label>Title URL <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
                  <input type="url" name="embedUrl" id="embedUrl" placeholder="https://..." value="<%= locals.formData?.embedUrl || '' %>" oninput="updatePreview()">
                </div>
              </div>
              <div class="form-group">
                <label>Description</label>
                <textarea name="embedDescription" id="embedDescription" placeholder="Embed description... (markdown supported)" oninput="updatePreview()"><%= locals.formData?.embedDescription || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Color</label>
                <div class="color-row">
                  <input type="color" id="colorPicker" value="<%= locals.formData?.embedColor || '#F5A623' %>" oninput="syncColor(this.value)">
                  <input type="text" name="embedColor" id="embedColor" placeholder="#5865F2" value="<%= locals.formData?.embedColor || '#F5A623' %>" oninput="syncColorText(this.value); updatePreview()">
                </div>
              </div>
              <div class="divider"></div>
              <div class="form-row">
                <div class="form-group">
                  <label>Image URL</label>
                  <input type="url" name="embedImage" id="embedImage" placeholder="https://..." value="<%= locals.formData?.embedImage || '' %>" oninput="updatePreview()">
                </div>
                <div class="form-group">
                  <label>Thumbnail URL</label>
                  <input type="url" name="embedThumbnail" id="embedThumbnail" placeholder="https://..." value="<%= locals.formData?.embedThumbnail || '' %>" oninput="updatePreview()">
                </div>
              </div>
              <div class="form-group">
                <label>Footer</label>
                <input type="text" name="embedFooter" id="embedFooter" placeholder="Footer text..." value="<%= locals.formData?.embedFooter || '' %>" oninput="updatePreview()">
              </div>
            </div>

            <!-- Raw fields -->
            <div id="rawFields" style="display:<%= (locals.formData?.mode === 'raw') ? 'block' : 'none' %>">
              <div class="form-group">
                <label>Message Content</label>
                <textarea name="rawContent" id="rawContent" placeholder="Type your message here... (markdown supported)" style="min-height:140px" oninput="updatePreview()"><%= locals.formData?.rawContent || '' %></textarea>
              </div>
            </div>

            <button type="submit" class="btn-send">
              <i class="fa fa-paper-plane"></i> Send Message
            </button>
          </div>

        </div>

        <!-- ── RIGHT: Live Preview ── -->
        <div>
          <div class="card" style="position:sticky;top:calc(var(--topbar-h) + 16px)">
            <div class="card-title"><i class="fa fa-eye"></i> Live Preview</div>

            <div class="webhook-row">
              <div id="previewAvatarWrap">
                <img id="previewAvatarImg" src="<%= bot.user.displayAvatarURL({ size: 64 }) %>" alt="" style="width:36px;height:36px;border-radius:50%;object-fit:cover" onerror="this.style.display='none';document.getElementById('previewAvatarFallback').style.display='flex'">
                <div id="previewAvatarFallback" class="webhook-avatar" style="display:none">W</div>
              </div>
              <div>
                <span class="webhook-name" id="previewName"><%= bot.user.username %></span>
                <span class="bot-tag">BOT</span>
              </div>
            </div>

            <div id="embedPreviewWrap">
              <div class="embed-preview" id="embedPreview" style="border-left-color:#F5A623">
                <div class="ep-empty" id="epEmpty">Fill in some fields to see a preview</div>
                <div id="epAuthor" class="ep-author" style="display:none"></div>
                <div id="epTitleWrap" style="display:none">
                  <div class="ep-title" id="epTitle"></div>
                </div>
                <div id="epThumbWrap" style="display:none"><img id="epThumb" class="ep-thumb" src="" alt=""></div>
                <div id="epDesc" class="ep-desc" style="display:none"></div>
                <img id="epImage" src="" alt="" class="ep-image" style="display:none">
                <div id="epFooter" class="ep-footer" style="display:none"></div>
              </div>
            </div>

            <div id="rawPreviewWrap" style="display:none">
              <div class="raw-preview" id="rawPreview"></div>
            </div>
          </div>
        </div>
      </div>
    </form>

    <%- include('../includes/footer') %>
  </div>
</div>

<script>
  let currentMode = document.getElementById('modeInput').value;

  function setMode(mode, btn) {
    currentMode = mode;
    document.getElementById('modeInput').value = mode;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('embedFields').style.display = mode === 'embed' ? 'block' : 'none';
    document.getElementById('rawFields').style.display  = mode === 'raw'   ? 'block' : 'none';
    document.getElementById('embedPreviewWrap').style.display = mode === 'embed' ? 'block' : 'none';
    document.getElementById('rawPreviewWrap').style.display   = mode === 'raw'   ? 'block' : 'none';
    updatePreview();
  }

  function syncColor(val) {
    document.getElementById('embedColor').value = val;
    updatePreview();
  }
  function syncColorText(val) {
    if (/^#[0-9a-fA-F]{6}$/.test(val)) {
      document.getElementById('colorPicker').value = val;
    }
  }

  function updatePreview() {
    // Webhook identity
    const name   = document.getElementById('webhookName').value.trim();
    const avatar = document.getElementById('webhookAvatar').value.trim();
    document.getElementById('previewName').textContent = name || '<%= bot.user.username %>';
    const img = document.getElementById('previewAvatarImg');
    if (avatar) { img.src = avatar; img.style.display = ''; document.getElementById('previewAvatarFallback').style.display = 'none'; }

    if (currentMode === 'raw') {
      const content = document.getElementById('rawContent').value;
      document.getElementById('rawPreview').textContent = content || '';
      return;
    }

    // Embed
    const title     = document.getElementById('embedTitle').value.trim();
    const desc      = document.getElementById('embedDescription').value.trim();
    const color     = document.getElementById('embedColor').value.trim() || '#F5A623';
    const image     = document.getElementById('embedImage').value.trim();
    const thumbnail = document.getElementById('embedThumbnail').value.trim();
    const footer    = document.getElementById('embedFooter').value.trim();
    const author    = document.getElementById('embedAuthor').value.trim();
    const url       = document.getElementById('embedUrl').value.trim();

    const hasContent = title || desc || image || thumbnail || footer || author;
    document.getElementById('epEmpty').style.display = hasContent ? 'none' : '';
    document.getElementById('embedPreview').style.borderLeftColor = /^#[0-9a-fA-F]{3,6}$/.test(color) ? color : '#F5A623';

    // Author
    const epAuthor = document.getElementById('epAuthor');
    epAuthor.textContent = author; epAuthor.style.display = author ? '' : 'none';

    // Title
    const epTitleWrap = document.getElementById('epTitleWrap');
    const epTitle = document.getElementById('epTitle');
    if (title) {
      epTitle.innerHTML = url ? `<a href="${url}" target="_blank" style="color:#00b0f4">${escHtml(title)}</a>` : escHtml(title);
      epTitleWrap.style.display = '';
    } else { epTitleWrap.style.display = 'none'; }

    // Thumbnail
    const epThumbWrap = document.getElementById('epThumbWrap');
    const epThumb = document.getElementById('epThumb');
    if (thumbnail) { epThumb.src = thumbnail; epThumbWrap.style.display = ''; } else { epThumbWrap.style.display = 'none'; }

    // Description
    const epDesc = document.getElementById('epDesc');
    epDesc.textContent = desc; epDesc.style.display = desc ? '' : 'none';

    // Image
    const epImage = document.getElementById('epImage');
    if (image) { epImage.src = image; epImage.style.display = ''; } else { epImage.style.display = 'none'; }

    // Footer
    const epFooter = document.getElementById('epFooter');
    epFooter.textContent = footer; epFooter.style.display = footer ? '' : 'none';
  }

  function escHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Init on load
  setMode(currentMode, document.querySelector('.tab-btn.active'));
  updatePreview();
</script>

</body>
</html>
