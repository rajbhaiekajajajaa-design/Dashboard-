<!DOCTYPE html>
<html lang="en">
<%- include('../includes/head') %>
<body>
<% locals.activePage = 'greeting'; %>
<%- include('../includes/sidebar') %>
<%- include('../includes/header') %>

<style>
  .main-content { margin-left: var(--sidebar-w); padding-top: var(--topbar-h); min-height: 100vh; }
  .page-inner { padding: 32px 28px; }
  .page-header { margin-bottom: 28px; }
  .page-header .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
  .page-header .breadcrumb a:hover { color: var(--accent); }
  .page-header .breadcrumb i { font-size: 10px; }
  .page-header h1 { font-size: 22px; font-weight: 700; }
  .settings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 20px; }
  .settings-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
  .card-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .card-header-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; }
  .card-header-icon.green { background: rgba(59,165,93,0.2); color: var(--success); }
  .card-header-icon.red { background: rgba(237,66,69,0.2); color: var(--danger); }
  .card-header h3 { font-size: 15px; font-weight: 600; margin: 0; }
  .card-body { padding: 20px; }
  .card-footer { padding: 14px 20px; border-top: 1px solid var(--border); display: flex; gap: 10px; justify-content: space-between; align-items: center; }
  .toggle-group { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); margin-bottom: 14px; }
  .toggle-label { font-size: 14px; color: var(--text-secondary); }
  .toggle { position: relative; width: 44px; height: 24px; cursor: pointer; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider { position: absolute; inset: 0; background: var(--bg-tertiary); border-radius: 24px; transition: .2s; border: 1px solid var(--border); }
  .toggle-slider:before { content: ''; position: absolute; width: 18px; height: 18px; left: 2px; bottom: 2px; background: var(--text-muted); border-radius: 50%; transition: .2s; }
  .toggle input:checked + .toggle-slider { background: var(--accent); border-color: var(--accent); }
  .toggle input:checked + .toggle-slider:before { transform: translateX(20px); background: #fff; }
  textarea { resize: vertical; min-height: 80px; }
  .status-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;
  }
  .status-badge.enabled { background: rgba(59,165,93,0.15); color: var(--success); }
  .status-badge.disabled { background: rgba(237,66,69,0.1); color: var(--danger); }
</style>

<div class="main-content">
  <div class="page-inner">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/selector">Servers</a>
        <i class="fa fa-chevron-right"></i>
        <a href="/manage/<%= guild.id %>/basic"><%= guild.name %></a>
        <i class="fa fa-chevron-right"></i>
        <span>Greeting</span>
      </div>
      <h1>Greeting Messages</h1>
    </div>

    <div class="settings-grid">

      <!-- WELCOME -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon green"><i class="fa fa-door-open"></i></div>
          <h3>Welcome Message</h3>
          <% if(guild.welcome.enabled) { %>
            <span class="status-badge enabled" style="margin-left:auto"><i class="fa fa-circle" style="font-size:8px"></i> Enabled</span>
          <% } else { %>
            <span class="status-badge disabled" style="margin-left:auto"><i class="fa fa-circle" style="font-size:8px"></i> Disabled</span>
          <% } %>
        </div>
        <form action="/manage/<%= guild.id %>/greeting" method="POST">
          <div class="card-body">
            <div class="form-group">
              <label>Message Content</label>
              <% if(guild.welcome.embed.description || guild.welcome.content) { %>
                <textarea name="content"><%- guild.welcome.content?.replaceAll(/\\n/g, '&#10;') %></textarea>
              <% } else { %>
                <textarea name="content" placeholder="Welcome to the server {member:name} 🎉"></textarea>
              <% } %>
            </div>
            <div class="form-group">
              <label>Embed Description</label>
              <textarea name="description"><%- guild.welcome.embed.description?.replaceAll(/\\n/g, '&#10;') %></textarea>
            </div>
            <div class="form-group">
              <label>Embed Footer</label>
              <input type="text" name="footer" value="<%= guild.welcome.embed.footer %>">
            </div>
            <div class="form-group">
              <label>Embed Color (hex)</label>
              <input type="text" name="hexcolor" value="<%= guild.welcome.embed.color %>" placeholder="#5865F2">
            </div>
            <div class="form-group">
              <label>Embed Image URL</label>
              <input type="text" name="image" value="<%= guild.welcome.embed.image %>">
            </div>
            <div class="form-group">
              <label>Channel</label>
              <select name="channel">
                <% if(bot.channels.cache.has(guild.welcome.channel)){ %>
                  <option selected>#<%= bot.channels.cache.get(guild.welcome.channel).name %></option>
                  <% guild.channels.cache.filter((ch) => ch.id !== guild.welcome.channel && ch.type === 0).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                <% } else { %>
                  <option disabled selected value> -- select a channel -- </option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                <% } %>
              </select>
            </div>
            <div class="toggle-group">
              <span class="toggle-label">Show User Thumbnail</span>
              <label class="toggle">
                <input type="checkbox" name="thumbnail" <%= guild.welcome.embed.thumbnail ? 'checked' : '' %>>
                <span class="toggle-slider"></span>
              </label>
            </div>
          </div>
          <div class="card-footer">
            <% if(guild.welcome.enabled){ %>
              <button type="submit" name="welcomeDisable" class="btn btn-danger"><i class="fa fa-times"></i> Disable</button>
              <button type="submit" name="welcomeUpdate" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
            <% } else { %>
              <button type="submit" name="welcomeEnable" class="btn btn-success"><i class="fa fa-check"></i> Enable</button>
            <% } %>
          </div>
        </form>
      </div>

      <!-- FAREWELL -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon red"><i class="fa fa-door-closed"></i></div>
          <h3>Farewell Message</h3>
          <% if(guild.farewell.enabled) { %>
            <span class="status-badge enabled" style="margin-left:auto"><i class="fa fa-circle" style="font-size:8px"></i> Enabled</span>
          <% } else { %>
            <span class="status-badge disabled" style="margin-left:auto"><i class="fa fa-circle" style="font-size:8px"></i> Disabled</span>
          <% } %>
        </div>
        <form action="/manage/<%= guild.id %>/greeting" method="POST">
          <div class="card-body">
            <div class="form-group">
              <label>Message Content</label>
              <% if(guild.farewell.embed.description || guild.farewell.content) { %>
                <textarea name="content"><%- guild.farewell.content?.replaceAll(/\\n/g, '&#10;') %></textarea>
              <% } else { %>
                <textarea name="content" placeholder="{member:tag} has left the server 👋"></textarea>
              <% } %>
            </div>
            <div class="form-group">
              <label>Embed Description</label>
              <textarea name="description"><%- guild.farewell.embed.description?.replaceAll(/\\n/g, '&#10;') %></textarea>
            </div>
            <div class="form-group">
              <label>Embed Footer</label>
              <input type="text" name="footer" value="<%= guild.farewell.embed.footer %>">
            </div>
            <div class="form-group">
              <label>Embed Color (hex)</label>
              <input type="text" name="hexcolor" value="<%= guild.farewell.embed.color %>" placeholder="#ED4245">
            </div>
            <div class="form-group">
              <label>Embed Image URL</label>
              <input type="text" name="image" value="<%= guild.farewell.embed.image %>">
            </div>
            <div class="form-group">
              <label>Channel</label>
              <select name="channel">
                <% if(bot.channels.cache.has(guild.farewell.channel)){ %>
                  <option selected>#<%= bot.channels.cache.get(guild.farewell.channel).name %></option>
                  <% guild.channels.cache.filter((ch) => ch.id !== guild.farewell.channel && ch.type === 0).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                <% } else { %>
                  <option disabled selected value> -- select a channel -- </option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                <% } %>
              </select>
            </div>
            <div class="toggle-group">
              <span class="toggle-label">Show User Thumbnail</span>
              <label class="toggle">
                <input type="checkbox" name="thumbnail" <%= guild.farewell.embed.thumbnail ? 'checked' : '' %>>
                <span class="toggle-slider"></span>
              </label>
            </div>
          </div>
          <div class="card-footer">
            <% if(guild.farewell.enabled){ %>
              <button type="submit" name="farewellDisable" class="btn btn-danger"><i class="fa fa-times"></i> Disable</button>
              <button type="submit" name="farewellUpdate" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
            <% } else { %>
              <button type="submit" name="farewellEnable" class="btn btn-success"><i class="fa fa-check"></i> Enable</button>
            <% } %>
          </div>
        </form>
      </div>

    </div>
    <%- include('../includes/footer') %>
  </div>
</div>
</body>
</html>
