<!DOCTYPE html>
<html lang="en">
<%- include('../includes/head') %>
<body>
<% locals.activePage = 'rolerewards'; %>
<%- include('../includes/sidebar') %>
<%- include('../includes/header') %>

<style>
  .main-content { margin-left: var(--sidebar-w); padding-top: var(--topbar-h); min-height: 100vh; }
  .page-inner { padding: 32px 28px; }
  .page-header { margin-bottom: 28px; }
  .page-header .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
  .page-header .breadcrumb a { color: var(--text-muted); text-decoration: none; }
  .page-header .breadcrumb a:hover { color: var(--accent); }
  .page-header .breadcrumb i { font-size: 10px; }
  .page-header h1 { font-size: 22px; font-weight: 700; }
  .page-header p { color: var(--text-muted); font-size: 14px; margin-top: 4px; }

  /* Warning banner */
  .warn-banner {
    display: flex; align-items: center; gap: 10px;
    background: rgba(240,165,0,0.1); border: 1px solid rgba(240,165,0,0.3);
    border-radius: 10px; padding: 12px 16px; margin-bottom: 20px;
    font-size: 13px; color: #f0a500;
  }
  .warn-banner a { color: #f0a500; }

  /* ──────────────── Builder card ──────────────── */
  .builder-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden; margin-bottom: 20px;
  }
  .builder-header {
    padding: 18px 24px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 12px;
  }
  .builder-header-icon {
    width: 36px; height: 36px; border-radius: 10px;
    background: rgba(59,165,93,0.15); color: #3ba55d;
    display: flex; align-items: center; justify-content: center; font-size: 16px;
  }
  .builder-header h3 { font-size: 16px; font-weight: 700; margin: 0; }
  .builder-header p { font-size: 13px; color: var(--text-muted); margin: 2px 0 0; }
  .builder-body { padding: 24px; display: grid; grid-template-columns: 260px 1fr; gap: 24px; }
  @media (max-width: 860px) { .builder-body { grid-template-columns: 1fr; } }

  /* Level input section */
  .level-picker { display: flex; flex-direction: column; gap: 10px; }
  .level-picker label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .9px; color: var(--text-muted); }
  .level-stepper {
    display: flex; align-items: center; gap: 0;
    background: var(--bg-tertiary); border: 2px solid var(--border);
    border-radius: 12px; overflow: hidden; transition: border-color .15s ease;
  }
  .level-stepper:focus-within { border-color: var(--accent); }
  .level-stepper button {
    width: 44px; height: 52px; background: none; border: none;
    color: var(--text-muted); font-size: 18px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: color .15s ease, background .15s ease;
  }
  .level-stepper button:hover { color: var(--accent); background: rgba(var(--accent-rgb),0.08); }
  .level-stepper input[type="number"] {
    flex: 1; height: 52px; background: none; border: none; outline: none;
    text-align: center; font-size: 28px; font-weight: 800; color: var(--text-primary);
    min-width: 0; -moz-appearance: textfield;
  }
  .level-stepper input::-webkit-outer-spin-button,
  .level-stepper input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .level-hint { font-size: 12px; color: var(--text-muted); line-height: 1.4; }

  /* Live preview */
  .reward-preview {
    background: var(--bg-tertiary); border: 1px dashed var(--border);
    border-radius: 12px; padding: 16px; display: flex; align-items: center; gap: 14px;
    transition: border-color .2s ease, background .2s ease; min-height: 72px;
  }
  .reward-preview.has-role { border-color: rgba(var(--accent-rgb),0.4); background: rgba(var(--accent-rgb),0.04); border-style: solid; }
  .preview-level-badge {
    flex-shrink: 0; width: 48px; height: 48px; border-radius: 50%;
    background: rgba(255,196,0,0.12); border: 2px solid rgba(255,196,0,0.3);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 0;
  }
  .preview-level-badge .num { font-size: 16px; font-weight: 800; color: #ffc400; line-height: 1; }
  .preview-level-badge .lbl { font-size: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: rgba(255,196,0,0.7); }
  .preview-arrow { color: var(--text-muted); font-size: 14px; }
  .preview-role-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--accent-glow); color: var(--accent);
    padding: 6px 14px; border-radius: 20px; font-size: 14px; font-weight: 700;
    transition: all .2s ease;
  }
  .preview-role-pill.empty { background: var(--bg-card); color: var(--text-muted); font-weight: 400; font-size: 13px; border: 1px dashed var(--border); }

  /* Role picker */
  .role-picker-section { display: flex; flex-direction: column; gap: 10px; }
  .role-picker-section label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .9px; color: var(--text-muted); }
  .role-search-wrap { position: relative; }
  .role-search-wrap i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 13px; pointer-events: none; }
  .role-search {
    width: 100%; padding: 9px 12px 9px 34px;
    background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 9px; color: var(--text-primary); font-size: 14px; outline: none;
    transition: border-color .15s ease; box-sizing: border-box;
  }
  .role-search:focus { border-color: var(--accent); }
  .role-grid {
    display: flex; flex-wrap: wrap; gap: 7px;
    max-height: 180px; overflow-y: auto;
    padding: 10px; background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 9px;
  }
  .role-grid::-webkit-scrollbar { width: 4px; }
  .role-grid::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  .role-chip {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 20px; font-size: 13px; font-weight: 600;
    border: 1.5px solid var(--border); background: var(--bg-card);
    color: var(--text-secondary); cursor: pointer;
    transition: all .15s ease; user-select: none; white-space: nowrap;
  }
  .role-chip:hover { border-color: var(--accent); color: var(--accent); background: rgba(var(--accent-rgb),0.06); }
  .role-chip.selected { border-color: var(--accent); color: var(--accent); background: rgba(var(--accent-rgb),0.13); box-shadow: 0 0 0 2px rgba(var(--accent-rgb),0.18); }
  .role-chip .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; opacity: .6; }
  .role-chip-none { font-size: 12px; color: var(--text-muted); padding: 8px; width: 100%; text-align: center; }

  .builder-footer {
    padding: 16px 24px; border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .builder-footer-hint { font-size: 12px; color: var(--text-muted); }

  /* ──────────────── Milestone rewards ──────────────── */
  .rewards-section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .rewards-section-header h2 { font-size: 17px; font-weight: 700; }
  .rewards-count { font-size: 13px; color: var(--text-muted); }

  .milestone-track { display: flex; flex-direction: column; gap: 0; }
  .milestone-item {
    display: flex; align-items: center; gap: 0; position: relative;
  }
  .milestone-item:not(:last-child)::after {
    content: ''; position: absolute; left: 23px; top: 52px;
    width: 2px; height: calc(100% - 4px); background: var(--border);
    z-index: 0;
  }
  .milestone-dot-wrap { flex-shrink: 0; width: 48px; display: flex; justify-content: center; z-index: 1; }
  .milestone-dot {
    width: 46px; height: 46px; border-radius: 50%;
    background: rgba(255,196,0,0.12); border: 2px solid rgba(255,196,0,0.35);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; margin: 3px 0;
  }
  .milestone-dot .num { font-size: 14px; font-weight: 800; color: #ffc400; line-height: 1; }
  .milestone-dot .lbl { font-size: 7px; font-weight: 700; text-transform: uppercase; letter-spacing: .4px; color: rgba(255,196,0,0.65); }
  .milestone-content {
    flex: 1; margin: 6px 0 6px 14px;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
    padding: 12px 16px; display: flex; align-items: center; gap: 12px;
    transition: border-color .15s ease;
  }
  .milestone-content:hover { border-color: rgba(var(--accent-rgb),0.3); }
  .milestone-role { display: flex; align-items: center; gap: 8px; flex: 1; }
  .milestone-role-icon { width: 30px; height: 30px; border-radius: 8px; background: var(--accent-glow); display: flex; align-items: center; justify-content: center; font-size: 13px; color: var(--accent); flex-shrink: 0; }
  .milestone-role-name { font-size: 14px; font-weight: 600; color: var(--text-primary); }
  .milestone-role-sub { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .milestone-remove {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 8px;
    background: rgba(237,66,69,0.08); border: 1px solid rgba(237,66,69,0.2);
    color: var(--danger); cursor: pointer; font-size: 12px;
    transition: background .15s ease, border-color .15s ease; flex-shrink: 0;
  }
  .milestone-remove:hover { background: rgba(237,66,69,0.18); border-color: rgba(237,66,69,0.45); }

  .empty-card {
    background: var(--bg-card); border: 1px dashed var(--border);
    border-radius: 14px; padding: 44px 20px; text-align: center; color: var(--text-muted);
  }
  .empty-card i { font-size: 36px; margin-bottom: 12px; display: block; opacity: .3; }
  .empty-card p { font-size: 14px; }
</style>

<div class="main-content">
  <div class="page-inner">

    <div class="page-header">
      <div class="breadcrumb">
        <a href="/selector">My Servers</a>
        <i class="fa fa-chevron-right"></i>
        <a href="/manage/<%= guild.id %>/basic"><%= guild.name %></a>
        <i class="fa fa-chevron-right"></i>
        <span>Role Rewards</span>
      </div>
      <h1><i class="fa fa-gift" style="color:var(--accent);margin-right:8px"></i>Level Role Rewards</h1>
      <p>Automatically grant a role to members the moment they reach a specific level.</p>
    </div>

    <% if (!statsEnabled) { %>
    <div class="warn-banner">
      <i class="fa fa-exclamation-triangle"></i>
      <span>The XP/leveling system is currently <strong>disabled</strong>. Role rewards won't trigger until it's turned on in
        <a href="/manage/<%= guild.id %>/basic">General Settings</a>.</span>
    </div>
    <% } %>

    <!-- ── Builder ── -->
    <form action="/manage/<%= guild.id %>/rolerewards" method="POST" id="rewardForm">
      <input type="hidden" name="role_id" id="selectedRoleId" />

      <div class="builder-card">
        <div class="builder-header">
          <div class="builder-header-icon"><i class="fa fa-plus"></i></div>
          <div>
            <h3>Add a New Reward</h3>
            <p>Choose a level milestone and the role members will receive when they reach it.</p>
          </div>
        </div>

        <div class="builder-body">

          <!-- Left: Level + Preview -->
          <div style="display:flex;flex-direction:column;gap:16px">
            <div class="level-picker">
              <label><i class="fa fa-star" style="margin-right:5px"></i>Milestone Level</label>
              <div class="level-stepper">
                <button type="button" onclick="stepLevel(-1)"><i class="fa fa-minus"></i></button>
                <input type="number" name="level" id="levelInput" min="1" max="9999" value="10" required oninput="updatePreview()" />
                <button type="button" onclick="stepLevel(1)"><i class="fa fa-plus"></i></button>
              </div>
              <div class="level-hint">Members reaching this level will automatically receive the selected role.</div>
            </div>

            <div>
              <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--text-muted);display:block;margin-bottom:8px">
                <i class="fa fa-eye" style="margin-right:5px"></i>Live Preview
              </label>
              <div class="reward-preview" id="previewCard">
                <div class="preview-level-badge">
                  <span class="num" id="previewLevel">10</span>
                  <span class="lbl">Level</span>
                </div>
                <i class="fa fa-long-arrow-alt-right preview-arrow"></i>
                <span class="preview-role-pill empty" id="previewRole">Select a role →</span>
              </div>
            </div>
          </div>

          <!-- Right: Role picker -->
          <div class="role-picker-section">
            <label><i class="fa fa-user-tag" style="margin-right:5px"></i>Role to Grant</label>
            <div class="role-search-wrap">
              <i class="fa fa-search"></i>
              <input type="text" class="role-search" id="roleSearch" placeholder="Search roles…" oninput="filterRoles(this.value)" autocomplete="off" />
            </div>
            <div class="role-grid" id="roleGrid">
              <% var assignableRoles = guild.roles.cache
                  .filter(function(r) { return !r.managed && r.name !== '@everyone'; })
                  .sort(function(a, b) { return b.position - a.position; }); %>
              <% if (assignableRoles.size === 0) { %>
                <div class="role-chip-none">No assignable roles found.</div>
              <% } else { %>
                <% assignableRoles.forEach(function(role) { %>
                  <div class="role-chip"
                       data-id="<%= role.id %>"
                       data-name="<%= role.name %>"
                       onclick="selectRole(this)">
                    <span class="dot"></span>
                    @<%= role.name %>
                  </div>
                <% }); %>
              <% } %>
            </div>
            <div style="font-size:12px;color:var(--text-muted)">
              <i class="fa fa-info-circle" style="margin-right:4px"></i>
              The bot's role must be ranked higher than the reward role in Discord.
            </div>
          </div>

        </div>

        <div class="builder-footer">
          <div class="builder-footer-hint" id="submitHint">Select a role to enable adding.</div>
          <button type="submit" name="addReward" class="btn btn-primary" id="submitBtn" disabled style="opacity:.5;cursor:not-allowed">
            <i class="fa fa-plus"></i> Add Reward
          </button>
        </div>
      </div>
    </form>

    <!-- ── Current Rewards ── -->
    <div class="rewards-section-header">
      <h2><i class="fa fa-list" style="color:var(--text-muted);margin-right:8px;font-size:15px"></i>Current Rewards</h2>
      <span class="rewards-count"><%= rewards.length %> reward<%= rewards.length !== 1 ? 's' : '' %> configured</span>
    </div>

    <% if (rewards.length === 0) { %>
      <div class="empty-card">
        <i class="fa fa-gift"></i>
        <p>No role rewards yet — add one above to get started.</p>
      </div>
    <% } else { %>
      <div class="milestone-track">
        <% rewards.forEach(function(r) { %>
        <div class="milestone-item">
          <div class="milestone-dot-wrap">
            <div class="milestone-dot">
              <span class="num"><%= r.level %></span>
              <span class="lbl">lvl</span>
            </div>
          </div>
          <div class="milestone-content">
            <div class="milestone-role">
              <div class="milestone-role-icon"><i class="fa fa-user-tag"></i></div>
              <div>
                <div class="milestone-role-name">@<%= r.role_name %></div>
                <div class="milestone-role-sub">Granted at Level <%= r.level %></div>
              </div>
            </div>
            <form action="/manage/<%= guild.id %>/rolerewards" method="POST">
              <input type="hidden" name="removeLevel" value="<%= r.level %>" />
              <input type="hidden" name="removeRoleId" value="<%= r.role_id %>" />
              <button type="submit" name="removeReward" class="milestone-remove"
                onclick="return confirm('Remove the Level <%= r.level %> reward for @<%= r.role_name %>?')"
                title="Remove reward">
                <i class="fa fa-times"></i>
              </button>
            </form>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>

  </div>
</div>

<script>
  var selectedRoleId = null;

  function stepLevel(delta) {
    var input = document.getElementById('levelInput');
    var val = Math.max(1, Math.min(9999, (parseInt(input.value) || 1) + delta));
    input.value = val;
    updatePreview();
  }

  function updatePreview() {
    var lvl = document.getElementById('levelInput').value || '?';
    document.getElementById('previewLevel').textContent = lvl;
  }

  function selectRole(chip) {
    document.querySelectorAll('.role-chip').forEach(function(c) { c.classList.remove('selected'); });
    chip.classList.add('selected');
    selectedRoleId = chip.dataset.id;
    document.getElementById('selectedRoleId').value = selectedRoleId;

    var name = chip.dataset.name;
    var pill = document.getElementById('previewRole');
    pill.textContent = '@' + name;
    pill.className = 'preview-role-pill';
    document.getElementById('previewCard').classList.add('has-role');

    var btn = document.getElementById('submitBtn');
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
    document.getElementById('submitHint').textContent = 'Level ' + (document.getElementById('levelInput').value || '?') + ' → @' + name;
  }

  function filterRoles(query) {
    var q = query.toLowerCase().trim();
    document.querySelectorAll('.role-chip').forEach(function(chip) {
      chip.style.display = (!q || chip.dataset.name.toLowerCase().includes(q)) ? '' : 'none';
    });
  }
</script>

</body>
</html>
