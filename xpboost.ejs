<!DOCTYPE html>
<html lang="en">
<%- include('../includes/head') %>
<body>
<% locals.activePage = 'xpboost'; %>
<%- include('../includes/sidebar') %>
<%- include('../includes/header') %>

<style>
  .main-content { margin-left: var(--sidebar-w); padding-top: var(--topbar-h); min-height: 100vh; }
  .page-inner { padding: 32px 28px; }
  .page-header { margin-bottom: 28px; }
  .page-header .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
  .page-header .breadcrumb a { color: var(--text-muted); text-decoration: none; }
  .page-header .breadcrumb a:hover { color: var(--accent); }
  .page-header .breadcrumb i { font-size: 10px; }
  .page-header h1 { font-size: 22px; font-weight: 700; }
  .page-header p { color: var(--text-muted); font-size: 14px; margin-top: 4px; }

  /* Warning banner */
  .warn-banner {
    display: flex; align-items: center; gap: 10px;
    background: rgba(240,165,0,0.1); border: 1px solid rgba(240,165,0,0.3);
    border-radius: 10px; padding: 12px 16px; margin-bottom: 20px;
    font-size: 13px; color: #f0a500;
  }
  .warn-banner a { color: #f0a500; }

  /* Grid layout */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
  @media (max-width: 900px) { .two-col { grid-template-columns: 1fr; } }

  /* Cards */
  .boost-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden; display: flex; flex-direction: column;
  }
  .boost-card-header {
    padding: 18px 20px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 12px;
  }
  .boost-card-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; font-size: 16px;
  }
  .boost-card-icon.purple { background: var(--accent-glow); color: var(--accent); }
  .boost-card-icon.orange { background: rgba(255,140,0,0.15); color: #ff8c00; }
  .boost-card-header h3 { font-size: 15px; font-weight: 700; margin: 0; }
  .boost-card-header p { font-size: 12px; color: var(--text-muted); margin: 2px 0 0; }
  .boost-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 14px; }
  .boost-card-footer { padding: 14px 20px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; }

  /* Form fields */
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .9px; color: var(--text-muted); }
  .field select, .field input[type="number"] {
    width: 100%; background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 9px; padding: 10px 12px; color: var(--text-primary); font-size: 14px;
    outline: none; transition: border-color .15s ease; box-sizing: border-box;
  }
  .field select:focus, .field input[type="number"]:focus { border-color: var(--accent); }
  .field .hint { font-size: 12px; color: var(--text-muted); }

  /* Multiplier preset buttons */
  .mult-row { display: flex; flex-direction: column; gap: 6px; }
  .mult-presets { display: flex; gap: 6px; flex-wrap: wrap; }
  .mult-btn {
    padding: 5px 12px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer;
    background: var(--bg-tertiary); border: 1.5px solid var(--border); color: var(--text-secondary);
    transition: all .14s ease;
  }
  .mult-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(var(--accent-rgb),0.07); }
  .mult-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(var(--accent-rgb),0.14); box-shadow: 0 0 0 2px rgba(var(--accent-rgb),0.15); }
  .mult-custom-wrap { display: flex; align-items: center; gap: 8px; margin-top: 4px; }
  .mult-custom-wrap input[type="number"] {
    width: 90px; background: var(--bg-tertiary); border: 1.5px solid var(--border);
    border-radius: 9px; padding: 7px 10px; color: var(--text-primary); font-size: 14px; font-weight: 700;
    outline: none; text-align: center; box-sizing: border-box;
    transition: border-color .15s ease; -moz-appearance: textfield;
  }
  .mult-custom-wrap input::-webkit-outer-spin-button,
  .mult-custom-wrap input::-webkit-inner-spin-button { -webkit-appearance: none; }
  .mult-custom-wrap input:focus { border-color: var(--accent); }
  .mult-custom-wrap span { font-size: 13px; color: var(--text-muted); font-weight: 600; }

  /* Active boosts list */
  .boosts-section { margin-bottom: 8px; }
  .boosts-section h2 { font-size: 17px; font-weight: 700; margin-bottom: 16px; }
  .boosts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 12px; }

  .boost-item {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 13px;
    padding: 14px 16px; display: flex; align-items: center; gap: 12px;
    transition: border-color .15s ease;
  }
  .boost-item:hover { border-color: rgba(var(--accent-rgb),0.3); }
  .boost-item-icon {
    width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 15px;
  }
  .boost-item-icon.role { background: var(--accent-glow); color: var(--accent); }
  .boost-item-icon.channel { background: rgba(255,140,0,0.15); color: #ff8c00; }
  .boost-item-info { flex: 1; min-width: 0; }
  .boost-item-name { font-size: 14px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .boost-item-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
  .mult-badge {
    flex-shrink: 0; padding: 4px 10px; border-radius: 20px; font-size: 13px; font-weight: 800;
    background: linear-gradient(135deg, rgba(var(--accent-rgb),0.2), rgba(124,92,252,0.2));
    border: 1px solid rgba(var(--accent-rgb),0.3); color: var(--accent); letter-spacing: .3px;
  }
  .boost-remove {
    flex-shrink: 0; width: 28px; height: 28px; border-radius: 7px;
    background: rgba(237,66,69,0.08); border: 1px solid rgba(237,66,69,0.2);
    color: var(--danger); cursor: pointer; font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s ease, border-color .15s ease;
  }
  .boost-remove:hover { background: rgba(237,66,69,0.18); border-color: rgba(237,66,69,0.45); }

  .empty-inline {
    padding: 24px; text-align: center; color: var(--text-muted); font-size: 13px;
    background: var(--bg-card); border: 1px dashed var(--border); border-radius: 12px;
  }
  .empty-inline i { margin-right: 6px; opacity: .5; }

  /* How it works */
  .info-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px;
    padding: 20px; margin-bottom: 24px;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px;
  }
  .info-item { display: flex; flex-direction: column; gap: 6px; }
  .info-item-icon { font-size: 20px; margin-bottom: 2px; }
  .info-item h4 { font-size: 13px; font-weight: 700; margin: 0; }
  .info-item p { font-size: 12px; color: var(--text-muted); margin: 0; line-height: 1.5; }
</style>

<div class="main-content">
  <div class="page-inner">

    <div class="page-header">
      <div class="breadcrumb">
        <a href="/selector">My Servers</a>
        <i class="fa fa-chevron-right"></i>
        <a href="/manage/<%= guild.id %>/basic"><%= guild.name %></a>
        <i class="fa fa-chevron-right"></i>
        <span>XP Boosts</span>
      </div>
      <h1><i class="fa fa-bolt" style="color:#ffc400;margin-right:8px"></i>XP Boost Manager</h1>
      <p>Give specific roles or channels a multiplier so their XP gains count for more.</p>
    </div>

    <% if (!statsEnabled) { %>
    <div class="warn-banner">
      <i class="fa fa-exclamation-triangle"></i>
      <span>The XP/leveling system is currently <strong>disabled</strong>. Boosts won't apply until it's turned on in
        <a href="/manage/<%= guild.id %>/basic">General Settings</a>.</span>
    </div>
    <% } %>

    <!-- How it works -->
    <div class="info-card">
      <div class="info-item">
        <div class="info-item-icon">🎭</div>
        <h4>Role Boosts</h4>
        <p>Members with a boosted role earn multiplied XP. Multiple role boosts stack together.</p>
      </div>
      <div class="info-item">
        <div class="info-item-icon">#️⃣</div>
        <h4>Channel Boosts</h4>
        <p>Messages sent in a boosted channel earn multiplied XP, regardless of the member's roles.</p>
      </div>
      <div class="info-item">
        <div class="info-item-icon">✖️</div>
        <h4>Multipliers Stack</h4>
        <p>If a member has a 2× role boost and chats in a 1.5× channel, they earn 3× XP total.</p>
      </div>
      <div class="info-item">
        <div class="info-item-icon">⚙️</div>
        <h4>Base XP Range</h4>
        <p>The base XP per message and global multiplier are set in <a href="/manage/<%= guild.id %>/basic" style="color:var(--accent)">General Settings</a>.</p>
      </div>
    </div>

    <!-- Add boosts -->
    <div class="two-col">

      <!-- Role Boost -->
      <div class="boost-card">
        <div class="boost-card-header">
          <div class="boost-card-icon purple"><i class="fa fa-user-tag"></i></div>
          <div>
            <h3>Add Role Boost</h3>
            <p>Members with this role earn extra XP</p>
          </div>
        </div>
        <form action="/manage/<%= guild.id %>/xpboost" method="POST">
          <div class="boost-card-body">
            <div class="field">
              <label><i class="fa fa-user-tag" style="margin-right:4px"></i>Role</label>
              <select name="boost_role_id" required>
                <option value="">-- Select a role --</option>
                <% guild.roles.cache
                    .filter(function(r) { return !r.managed && r.name !== '@everyone'; })
                    .sort(function(a,b) { return b.position - a.position; })
                    .forEach(function(role) { %>
                  <option value="<%= role.id %>">@<%= role.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="mult-row">
              <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--text-muted)">
                <i class="fa fa-times" style="margin-right:4px"></i>Multiplier
              </label>
              <div class="mult-presets">
                <button type="button" class="mult-btn" onclick="setMult('roleMultInput','roleMultBtns',this,1.5)">1.5×</button>
                <button type="button" class="mult-btn" onclick="setMult('roleMultInput','roleMultBtns',this,2)">2×</button>
                <button type="button" class="mult-btn" onclick="setMult('roleMultInput','roleMultBtns',this,3)">3×</button>
                <button type="button" class="mult-btn" onclick="setMult('roleMultInput','roleMultBtns',this,5)">5×</button>
              </div>
              <div class="mult-custom-wrap" id="roleMultBtns">
                <input type="number" id="roleMultInput" name="boost_role_mult" min="1.1" max="100" step="0.1" value="2" required oninput="clearPresets('roleMultBtns')" />
                <span>× XP multiplier</span>
              </div>
              <div class="hint" style="font-size:12px;color:var(--text-muted)">Adding an existing role overwrites its current multiplier.</div>
            </div>
          </div>
          <div class="boost-card-footer">
            <button type="submit" name="addRoleBoost" class="btn btn-primary">
              <i class="fa fa-plus"></i> Add Role Boost
            </button>
          </div>
        </form>
      </div>

      <!-- Channel Boost -->
      <div class="boost-card">
        <div class="boost-card-header">
          <div class="boost-card-icon orange"><i class="fa fa-hashtag"></i></div>
          <div>
            <h3>Add Channel Boost</h3>
            <p>Messages in this channel earn extra XP</p>
          </div>
        </div>
        <form action="/manage/<%= guild.id %>/xpboost" method="POST">
          <div class="boost-card-body">
            <div class="field">
              <label><i class="fa fa-hashtag" style="margin-right:4px"></i>Channel</label>
              <select name="boost_channel_id" required>
                <option value="">-- Select a channel --</option>
                <% guild.channels.cache
                    .filter(function(c) { return c.type === 0; })
                    .sort(function(a,b) { return a.name.localeCompare(b.name); })
                    .forEach(function(ch) { %>
                  <option value="<%= ch.id %>">#<%= ch.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="mult-row">
              <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--text-muted)">
                <i class="fa fa-times" style="margin-right:4px"></i>Multiplier
              </label>
              <div class="mult-presets">
                <button type="button" class="mult-btn" onclick="setMult('chMultInput','chMultBtns',this,1.5)">1.5×</button>
                <button type="button" class="mult-btn" onclick="setMult('chMultInput','chMultBtns',this,2)">2×</button>
                <button type="button" class="mult-btn" onclick="setMult('chMultInput','chMultBtns',this,3)">3×</button>
                <button type="button" class="mult-btn" onclick="setMult('chMultInput','chMultBtns',this,5)">5×</button>
              </div>
              <div class="mult-custom-wrap" id="chMultBtns">
                <input type="number" id="chMultInput" name="boost_channel_mult" min="1.1" max="100" step="0.1" value="2" required oninput="clearPresets('chMultBtns')" />
                <span>× XP multiplier</span>
              </div>
              <div class="hint" style="font-size:12px;color:var(--text-muted)">Adding an existing channel overwrites its current multiplier.</div>
            </div>
          </div>
          <div class="boost-card-footer">
            <button type="submit" name="addChannelBoost" class="btn btn-primary">
              <i class="fa fa-plus"></i> Add Channel Boost
            </button>
          </div>
        </form>
      </div>

    </div>

    <!-- Active Role Boosts -->
    <div class="boosts-section">
      <h2>
        <i class="fa fa-user-tag" style="font-size:15px;color:var(--accent);margin-right:8px"></i>
        Active Role Boosts
        <span style="font-size:13px;font-weight:400;color:var(--text-muted);margin-left:8px"><%= roleBoosts.length %> configured</span>
      </h2>
      <% if (roleBoosts.length === 0) { %>
        <div class="empty-inline"><i class="fa fa-user-tag"></i>No role boosts yet — add one above.</div>
      <% } else { %>
        <div class="boosts-grid">
          <% roleBoosts.forEach(function(b) { %>
          <div class="boost-item">
            <div class="boost-item-icon role"><i class="fa fa-user-tag"></i></div>
            <div class="boost-item-info">
              <div class="boost-item-name">@<%= b.name %></div>
              <div class="boost-item-sub">Role XP Boost</div>
            </div>
            <span class="mult-badge"><%= b.multiplier %>×</span>
            <form action="/manage/<%= guild.id %>/xpboost" method="POST">
              <input type="hidden" name="removeId" value="<%= b.id %>" />
              <button type="submit" name="removeRoleBoost" class="boost-remove"
                onclick="return confirm('Remove the <%= b.multiplier %>× boost for @<%= b.name %>?')"
                title="Remove boost">
                <i class="fa fa-times"></i>
              </button>
            </form>
          </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Active Channel Boosts -->
    <div class="boosts-section" style="margin-top:24px">
      <h2>
        <i class="fa fa-hashtag" style="font-size:15px;color:#ff8c00;margin-right:8px"></i>
        Active Channel Boosts
        <span style="font-size:13px;font-weight:400;color:var(--text-muted);margin-left:8px"><%= channelBoosts.length %> configured</span>
      </h2>
      <% if (channelBoosts.length === 0) { %>
        <div class="empty-inline"><i class="fa fa-hashtag"></i>No channel boosts yet — add one above.</div>
      <% } else { %>
        <div class="boosts-grid">
          <% channelBoosts.forEach(function(b) { %>
          <div class="boost-item">
            <div class="boost-item-icon channel"><i class="fa fa-hashtag"></i></div>
            <div class="boost-item-info">
              <div class="boost-item-name">#<%= b.name %></div>
              <div class="boost-item-sub">Channel XP Boost</div>
            </div>
            <span class="mult-badge"><%= b.multiplier %>×</span>
            <form action="/manage/<%= guild.id %>/xpboost" method="POST">
              <input type="hidden" name="removeId" value="<%= b.id %>" />
              <button type="submit" name="removeChannelBoost" class="boost-remove"
                onclick="return confirm('Remove the <%= b.multiplier %>× boost for #<%= b.name %>?')"
                title="Remove boost">
                <i class="fa fa-times"></i>
              </button>
            </form>
          </div>
          <% }); %>
        </div>
      <% } %>
    </div>

  </div>
</div>

<script>
  function setMult(inputId, groupId, btn, val) {
    document.getElementById(inputId).value = val;
    document.querySelectorAll('#' + groupId).forEach(function(el) {
      el.querySelectorAll('.mult-btn').forEach(function(b) { b.classList.remove('active'); });
    });
    btn.classList.add('active');
  }
  function clearPresets(groupId) {
    document.querySelectorAll('#' + groupId + ' .mult-btn').forEach(function(b) { b.classList.remove('active'); });
  }
</script>

</body>
</html>
