<!DOCTYPE html>
<html lang="en">
<%- include('../includes/head') %>
<body>
<% locals.activePage = 'autorole'; %>
<%- include('../includes/sidebar') %>
<%- include('../includes/header') %>

<style>
  .main-content { margin-left: var(--sidebar-w); padding-top: var(--topbar-h); min-height: 100vh; }
  .page-inner { padding: 32px 28px; }
  .page-header { margin-bottom: 28px; }
  .page-header .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
  .page-header .breadcrumb a:hover { color: var(--accent); }
  .page-header .breadcrumb i { font-size: 10px; }
  .page-header h1 { font-size: 22px; font-weight: 700; }
  .settings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 20px; }
  .settings-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
  .card-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .card-header-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; }
  .card-header-icon.purple { background: var(--accent-glow); color: var(--accent); }
  .card-header-icon.pink { background: rgba(255,105,180,0.15); color: #ff69b4; }
  .card-header h3 { font-size: 15px; font-weight: 600; margin: 0; }
  .card-body { padding: 20px; }
  .card-footer { padding: 14px 20px; border-top: 1px solid var(--border); display: flex; gap: 10px; justify-content: flex-end; }
  .current-value { display: inline-block; background: var(--bg-tertiary); border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px; font-size: 13px; color: var(--accent); margin-bottom: 10px; }
</style>

<div class="main-content">
  <div class="page-inner">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/selector">Servers</a>
        <i class="fa fa-chevron-right"></i>
        <a href="/manage/<%= guild.id %>/basic"><%= guild.name %></a>
        <i class="fa fa-chevron-right"></i>
        <span>Auto Role & Boost</span>
      </div>
      <h1>Auto Role & Boost</h1>
    </div>

    <div class="settings-grid">

      <!-- AUTO ROLE -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon purple"><i class="fa fa-user-tag"></i></div>
          <h3>Auto Role</h3>
        </div>
        <form action="/manage/<%= guild.id %>/autorole" method="POST">
          <div class="card-body">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px">Automatically assign a role when a new member joins.</p>
            <% if(guild.autorole && bot.roles?.cache?.has(guild.autorole)){ %>
              <div>Current: <span class="current-value">@<%= bot.guilds.cache.get(guild.id)?.roles.cache.get(guild.autorole)?.name || guild.autorole %></span></div>
            <% } %>
            <div class="form-group">
              <label>Select Role</label>
              <select name="autorole">
                <option value="">-- None --</option>
                <% guild.roles.cache.filter(r => !r.managed && r.name !== '@everyone').sort((a,b) => b.position - a.position).forEach((role) => { %>
                  <option <%= guild.autorole === role.id ? 'selected' : '' %>>@<%= role.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="card-footer">
            <% if(guild.autorole) { %>
              <button type="submit" name="autoroleDisable" class="btn btn-danger"><i class="fa fa-times"></i> Remove</button>
            <% } %>
            <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          </div>
        </form>
      </div>

      <!-- BOOST -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon pink"><i class="fa fa-rocket"></i></div>
          <h3>Boost Message</h3>
        </div>
        <form action="/manage/<%= guild.id %>/autorole" method="POST">
          <div class="card-body">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px">Send a message when a member boosts the server.</p>
            <div class="form-group">
              <label>Boost Channel</label>
              <select name="boost_channel">
                <option value="">-- None --</option>
                <% if(guild.boost?.channel && bot.channels.cache.has(guild.boost.channel)){ %>
                  <option selected>#<%= bot.channels.cache.get(guild.boost.channel).name %></option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0 && ch.id !== guild.boost.channel).forEach((ch) => { %><option>#<%= ch.name %></option><% }); %>
                <% } else { %>
                  <% guild.channels.cache.filter((ch) => ch.type === 0).forEach((ch) => { %><option>#<%= ch.name %></option><% }); %>
                <% } %>
              </select>
            </div>
            <div class="form-group">
              <label>Boost Message</label>
              <textarea name="boost_message" placeholder="Thanks {member:name} for boosting! 🚀"><%= guild.boost?.message || '' %></textarea>
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          </div>
        </form>
      </div>

    </div>

    <%- include('../includes/footer') %>
  </div>
</div>
</body>
</html>
