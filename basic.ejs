<!DOCTYPE html>
<html lang="en">
<%- include('../includes/head') %>
<body>
<% locals.activePage = 'basic'; %>
<%- include('../includes/sidebar') %>
<%- include('../includes/header') %>

<style>
  .main-content { margin-left: var(--sidebar-w); padding-top: var(--topbar-h); min-height: 100vh; }
  .page-inner { padding: 32px 28px; }
  .page-header { margin-bottom: 28px; }
  .page-header .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
  .page-header .breadcrumb a:hover { color: var(--accent); }
  .page-header .breadcrumb i { font-size: 10px; }
  .page-header h1 { font-size: 22px; font-weight: 700; }
  .settings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 20px; }
  .settings-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; overflow: hidden;
  }
  .card-header {
    padding: 16px 20px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .card-header-icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: var(--accent-glow); display: flex; align-items: center; justify-content: center;
    color: var(--accent); font-size: 14px;
  }
  .card-header h3 { font-size: 15px; font-weight: 600; margin: 0; }
  .card-body { padding: 20px; }
  .card-footer { padding: 14px 20px; border-top: 1px solid var(--border); display: flex; gap: 10px; justify-content: flex-end; }
  .toggle-group { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .toggle-group:last-child { border-bottom: none; padding-bottom: 0; }
  .toggle-label { font-size: 14px; color: var(--text-secondary); }
  .toggle {
    position: relative; width: 44px; height: 24px; cursor: pointer;
  }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider {
    position: absolute; inset: 0; background: var(--bg-tertiary);
    border-radius: 24px; transition: .2s; border: 1px solid var(--border);
  }
  .toggle-slider:before {
    content: ''; position: absolute;
    width: 18px; height: 18px; left: 2px; bottom: 2px;
    background: var(--text-muted); border-radius: 50%; transition: .2s;
  }
  .toggle input:checked + .toggle-slider { background: var(--accent); border-color: var(--accent); }
  .toggle input:checked + .toggle-slider:before { transform: translateX(20px); background: #fff; }
  .btn-warning { background: #f0a500; color: #fff; border: none; }
  .btn-warning:hover { background: #d4920a; }
  .btn-danger { background: var(--danger); color: #fff; border: none; }
  .btn-danger:hover { background: #b5282b; }
  .action-result {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; margin-bottom: 14px;
  }
  .result-success { background: rgba(59,165,93,0.15); border: 1px solid rgba(59,165,93,0.3); color: #3ba55d; }
  .result-error { background: rgba(237,66,69,0.15); border: 1px solid rgba(237,66,69,0.3); color: var(--danger); }
</style>

<div class="main-content">
  <div class="page-inner">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/selector">Servers</a>
        <i class="fa fa-chevron-right"></i>
        <a href="/manage/<%= guild.id %>/basic"><%= guild.name %></a>
        <i class="fa fa-chevron-right"></i>
        <span>General</span>
      </div>
      <h1>General Settings</h1>
    </div>

    <div class="settings-grid">

      <!-- GENERAL -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon"><i class="fa fa-sliders-h"></i></div>
          <h3>General</h3>
        </div>
        <form action="/manage/<%= guild.id %>/basic/" method="POST">
          <div class="card-body">
            <div class="form-group">
              <label>Command Prefix</label>
              <input type="text" name="prefix" placeholder="<%= guild.prefix %>">
            </div>
            <div class="toggle-group">
              <span class="toggle-label">Flag Translation</span>
              <label class="toggle">
                <input type="checkbox" name="flag_translation" <%= guild.flag_translation?.enabled ? 'checked' : '' %>>
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="toggle-group">
              <span class="toggle-label">Invite Tracking</span>
              <label class="toggle">
                <input type="checkbox" name="invite_tracking" <%= guild.invite.tracking ? 'checked' : '' %>>
                <span class="toggle-slider"></span>
              </label>
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" name="basicUpdate" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          </div>
        </form>
      </div>

      <!-- STATISTICS -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon"><i class="fa fa-chart-bar"></i></div>
          <h3>Statistics & Leveling</h3>
        </div>
        <form action="/manage/<%= guild.id %>/basic/" method="POST">
          <div class="card-body">
            <div class="toggle-group">
              <span class="toggle-label">XP Tracking</span>
              <label class="toggle">
                <input type="checkbox" name="ranking" <%= guild.stats.enabled ? 'checked' : '' %>>
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="form-group" style="margin-top:16px">
              <label>Level Up Message</label>
              <input type="text" name="levelup_message" placeholder="<%= guild.stats.xp.message %>">
            </div>
            <div class="form-group">
              <label>Level Up Channel</label>
              <select name="levelup_channel">
                <% if(guild.stats.xp.channel && bot.channels.cache.has(guild.stats.xp.channel)){ %>
                  <option selected="#<%= bot.channels.cache.get(guild.stats.xp.channel).name %>">
                    #<%= bot.channels.cache.get(guild.stats.xp.channel).name %>
                  </option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0 && ch.id !== guild.stats.xp.channel).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                  <option>No channel</option>
                <% } else { %>
                  <option disabled selected value> -- select a channel -- </option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                <% } %>
              </select>
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" name="statsUpdate" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          </div>
        </form>
      </div>

      <!-- TICKET -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon"><i class="fa fa-ticket-alt"></i></div>
          <h3>Ticket System</h3>
        </div>
        <form action="/manage/<%= guild.id %>/basic/" method="POST">
          <div class="card-body">
            <div class="form-group">
              <label>Max Tickets per User</label>
              <input type="number" name="limit" placeholder="<%= guild.ticket.limit %>">
            </div>
            <div class="form-group">
              <label>Ticket Logs Channel</label>
              <select name="channel">
                <% if(guild.ticket.log_channel && bot.channels.cache.has(guild.ticket.log_channel)){ %>
                  <option selected>#<%= bot.channels.cache.get(guild.ticket.log_channel).name %></option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0 && ch.id !== guild.ticket.log_channel).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                  <option>No channel</option>
                <% } else { %>
                  <option disabled selected value> -- select a channel -- </option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                <% } %>
              </select>
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" name="ticketUpdate" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          </div>
        </form>
      </div>

      <!-- MODERATION -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon"><i class="fa fa-shield-alt"></i></div>
          <h3>Moderation</h3>
        </div>
        <form action="/manage/<%= guild.id %>/basic/" method="POST">
          <div class="card-body">
            <div class="form-group">
              <label>Max Warnings</label>
              <input type="number" name="max_warnings" placeholder="<%= guild.max_warn.limit %>">
            </div>
            <div class="form-group">
              <label>Action on Max Warnings</label>
              <select name="max_warn_action">
                <option selected><%= guild.max_warn.action %></option>
                <% if(guild.max_warn.action !== "TIMEOUT") { %><option>TIMEOUT</option><% } %>
                <% if(guild.max_warn.action !== "KICK") { %><option>KICK</option><% } %>
                <% if(guild.max_warn.action !== "BAN") { %><option>BAN</option><% } %>
              </select>
            </div>
            <div class="form-group">
              <label>Mod Logs Channel</label>
              <select name="modlog_channel">
                <% if(guild.modlog_channel && bot.channels.cache.has(guild.modlog_channel)){ %>
                  <option selected>#<%= bot.channels.cache.get(guild.modlog_channel).name %></option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0 && ch.id !== guild.modlog_channel).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                  <option>No channel</option>
                <% } else { %>
                  <option disabled selected value> -- select a channel -- </option>
                  <% guild.channels.cache.filter((ch) => ch.type === 0).forEach((ch) => { %>
                    <option>#<%= ch.name %></option>
                  <% }); %>
                <% } %>
              </select>
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" name="modUpdate" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          </div>
        </form>
      </div>

      <!-- AUTO MOD -->
      <div class="settings-card">
        <div class="card-header">
          <div class="card-header-icon"><i class="fa fa-robot"></i></div>
          <h3>Auto Moderation</h3>
        </div>
        <form action="/manage/<%= guild.id %>/basic/" method="POST">
          <div class="card-body">
            <div class="form-group">
              <label>Max Strikes</label>
              <input type="number" name="max_strikes" placeholder="<%= guild.automod.strikes %>">
            </div>
            <div class="form-group">
              <label>Action on Max Strikes</label>
              <select name="automod_action">
                <option selected><%= guild.automod.action %></option>
                <% if(guild.automod.action !== "TIMEOUT") { %><option>TIMEOUT</option><% } %>
                <% if(guild.automod.action !== "KICK") { %><option>KICK</option><% } %>
                <% if(guild.automod.action !== "BAN") { %><option>BAN</option><% } %>
              </select>
            </div>
            <div class="form-group">
              <label>Max Lines per Message</label>
              <input type="number" name="max_lines" placeholder="<%= guild.automod.max_lines %>">
            </div>
            <div style="margin-bottom:12px">
              <label style="margin-bottom:10px">Filters</label>
              <% const filters = [
                ['anti_attachments', 'Anti Attachments', guild.automod.anti_attachments],
                ['anti_invites', 'Anti Invites', guild.automod.anti_invites],
                ['anti_links', 'Anti Links', guild.automod.anti_links],
                ['anti_spam', 'Anti Spam', guild.automod.anti_spam],
                ['anti_ghostping', 'Anti Ghost Ping', guild.automod.anti_ghostping],
                ['anti_massmention', 'Anti Mass Mention', guild.automod.anti_massmention],
              ]; %>
              <% filters.forEach(([name, label, checked]) => { %>
              <div class="toggle-group">
                <span class="toggle-label"><%= label %></span>
                <label class="toggle">
                  <input type="checkbox" name="<%= name %>" <%= checked ? 'checked' : '' %>>
                  <span class="toggle-slider"></span>
                </label>
              </div>
              <% }); %>
            </div>
            <div class="form-group">
              <label>Whitelisted Channels</label>
              <select name="channels" multiple style="height:100px">
                <% guild.channels.cache.filter((ch) => ch.type === 0).forEach((ch) => { %>
                  <option <%= guild.automod.wh_channels.includes(ch.id) ? 'selected' : '' %>>#<%= ch.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" name="automodUpdate" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          </div>
        </form>
      </div>

      <!-- MEMBER ACTIONS -->
      <div class="settings-card" style="grid-column: 1 / -1;">
        <div class="card-header">
          <div class="card-header-icon"><i class="fa fa-user-slash"></i></div>
          <h3>Member Actions</h3>
        </div>
        <form id="memberActionForm" action="/manage/<%= guild.id %>/member-action" method="POST">
          <div class="card-body">
            <% if (locals.actionResults && actionResults.length) { %>
              <div style="margin-bottom:16px;">
                <% actionResults.forEach(r => { %>
                  <div class="action-result <%= r.success ? 'result-success' : 'result-error' %>" style="margin-bottom:6px;">
                    <i class="fa <%= r.success ? 'fa-check-circle' : 'fa-times-circle' %>"></i>
                    <%= r.message %>
                  </div>
                <% }); %>
              </div>
            <% } %>

            <!-- Member List -->
            <div class="form-group">
              <label style="margin-bottom:8px;display:block;">Server Members (<%= guild.members.cache.filter(m => !m.user.bot && m.id !== bot.user.id).size %>)</label>
              <div style="max-height:260px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;padding:8px;background:var(--bg-secondary);">
                <% guild.members.cache.filter(m => !m.user.bot && m.id !== bot.user.id).sort((a,b) => a.user.username.localeCompare(b.user.username)).forEach(m => { %>
                  <div style="display:flex;align-items:center;gap:10px;padding:6px 8px;border-radius:6px;">
                    <img src="<%= m.user.displayAvatarURL({ size: 32 }) %>" style="width:28px;height:28px;border-radius:50%;object-fit:cover;"
                         onerror="this.style.display='none'">
                    <div style="flex:1;min-width:0;">
                      <div style="font-size:13px;font-weight:500;color:var(--text-primary);"><%= m.user.username %></div>
                      <div style="font-size:11px;color:var(--text-muted);">ID: <%= m.id %></div>
                    </div>
                    <div style="display:flex;gap:6px;">
                      <button type="button" onclick="quickAction('<%= m.id %>', 'KICK')" style="padding:4px 10px;font-size:11px;border:none;border-radius:5px;background:#f0a500;color:#fff;cursor:pointer;font-weight:600;"><i class="fa fa-user-minus"></i> Kick</button>
                      <button type="button" onclick="quickAction('<%= m.id %>', 'BAN')" style="padding:4px 10px;font-size:11px;border:none;border-radius:5px;background:#d32f2f;color:#fff;cursor:pointer;font-weight:600;"><i class="fa fa-ban"></i> Ban</button>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>

            <!-- Multi-member input -->
            <div class="form-group">
              <label>Usernames or User IDs <span style="color:var(--text-muted);font-size:12px">(one per line)</span></label>
              <textarea id="memberInput" name="member_ids" rows="4" placeholder="username1&#10;username2&#10;123456789012345678" style="width:100%;resize:vertical;font-family:monospace;font-size:13px;"></textarea>
            </div>
            <div class="form-group">
              <label>Reason <span style="color:var(--text-muted);font-size:12px">(optional)</span></label>
              <input type="text" name="reason" placeholder="Enter a reason...">
            </div>
          </div>
          <div class="card-footer">
            <button type="submit" name="action" value="KICK" class="btn btn-warning"><i class="fa fa-user-minus"></i> Kick All</button>
            <button type="submit" name="action" value="BAN" class="btn btn-danger"><i class="fa fa-ban"></i> Ban All</button>
          </div>
        </form>
      </div>
      <script>
        function quickAction(memberId, action) {
          const form = document.getElementById('memberActionForm');
          document.getElementById('memberInput').value = memberId;
          const btn = document.createElement('input');
          btn.type = 'hidden'; btn.name = 'action'; btn.value = action;
          form.appendChild(btn);
          form.submit();
        }
      </script>

    </div>
    <%- include('../includes/footer') %>
  </div>
</div>
</body>
</html>
